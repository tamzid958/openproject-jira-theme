# OpenProject OAuth integration via NextAuth (Auth.js v5).
#
# This frontend signs each user into OpenProject via OAuth 2.0
# (Authorization Code + PKCE). OpenProject is the backend / identity provider.
#
# One-time admin setup in OpenProject:
#   Administration → Authentication → OAuth applications → Add
#     Name:         Jira-Theme Frontend
#     Redirect URI: <AUTH_URL>/api/auth/callback/openproject
#     Confidential: yes
#     Scopes:       api_v3
#   Save, then copy the Client ID / Client Secret here.

OPENPROJECT_URL=https://openproject.example.com

OPENPROJECT_OAUTH_CLIENT_ID=
OPENPROJECT_OAUTH_CLIENT_SECRET=

# Public origin (NextAuth auto-detects in dev, but explicit is safer).
AUTH_URL=http://localhost:3000

# 32+ char secret used to sign NextAuth JWT cookies.
# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# Which field carries story points on your work packages.
# Accepts either a top-level numeric field (e.g. "storyPoints") or a HAL link
# field whose .title is the value (e.g. "customField7" for a CustomOption like
# Size: S/M/L/XL — t-shirt values get auto-mapped to Fibonacci numbers).
OPENPROJECT_STORY_POINTS_FIELD=storyPoints
